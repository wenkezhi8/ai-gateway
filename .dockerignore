# ============================================
# Docker Ignore File
# Excludes unnecessary files from build context
# ============================================

# Git
.git
.gitignore

# Documentation
*.md
docs/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Node modules (will be installed in container)
web/node_modules/

# Build artifacts
web/dist/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test files
*_test.go
test/
tests/

# Development files
.env
.env.local
*.log
logs/

# Data directories (mounted as volumes)
data/
backups/

# Docker files (not needed in context)
docker-compose*.yml
.docker/

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Temporary files
tmp/
temp/
*.tmp
*.temp

# OS files
.DS_Store
Thumbs.db

# Backup files
*.bak
*.backup
