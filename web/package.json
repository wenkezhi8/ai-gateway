{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "concurrently -n \"mock,vite\" -c \"yellow,blue\" \"node mock-server.mjs\" \"vite\"",
    "mock": "node mock-server.mjs",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,ts,vue,json,css,scss,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,vue,json,css,scss,md}\"",
    "typecheck": "vue-tsc --noEmit",
    "test": "playwright test",
    "test:unit": "vitest run",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:install": "playwright install",
    "test:auth": "playwright test tests/scenarios/auth.spec.ts",
    "test:dashboard": "playwright test tests/scenarios/dashboard.spec.ts",
    "test:providers": "playwright test tests/scenarios/providers.spec.ts",
    "test:accounts": "playwright test tests/scenarios/accounts.spec.ts",
    "test:navigation": "playwright test tests/scenarios/navigation.spec.ts",
    "test:data-loading": "playwright test tests/scenarios/data-loading.spec.ts",
    "test:performance": "playwright test tests/scenarios/performance-errors.spec.ts",
    "test:e2e": "playwright test tests/scenarios/e2e.spec.ts",
    "test:all": "playwright test tests/scenarios/",
    "test:generate-report": "node tests/utils/generate-report.js"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@types/markdown-it": "^14.1.2",
    "axios": "^1.13.5",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.2",
    "markdown-it": "^14.1.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.25",
    "vue-echarts": "^8.0.1",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.10.13",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.30.0",
    "prettier": "^3.2.5",
    "sass": "^1.97.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.3.1",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^3.1.5",
    "vitest": "^3.2.4"
  }
}
