{
  "always_allowed": [
    "README.md",
    "CHANGELOG.md",
    "docs/**",
    ".gitignore"
  ],
  "rules": [
    {
      "labels": ["frontend", "ui"],
      "allowed_paths": ["web/**", "docs/**"]
    },
    {
      "labels": ["backend", "api"],
      "allowed_paths": ["internal/**", "cmd/**", "pkg/**", "go.mod", "go.sum", "docs/**"]
    },
    {
      "labels": ["ci/cd", "release"],
      "allowed_paths": [".github/**", "scripts/**", "docs/**"]
    },
    {
      "labels": ["docs"],
      "allowed_paths": ["docs/**", "README.md", "CHANGELOG.md"]
    },
    {
      "labels": ["full-scope"],
      "allowed_paths": ["**"]
    }
  ]
}
