# ============================================
# AI Gateway - Environment Configuration
# Copy this file to .env and configure your settings
# ============================================

# ===========================================
# Server Ports
# ===========================================
GATEWAY_PORT=8000
WEB_PORT=3000
REDIS_PORT=6379

# ===========================================
# API Keys (Required)
# Get your keys from:
# - OpenAI: https://platform.openai.com/api-keys
# - Anthropic: https://console.anthropic.com/settings/keys
# - Azure: https://portal.azure.com
# - Volcano Ark: https://console.volcengine.com/ark
# ===========================================
# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BACKUP_API_KEY=sk-your-openai-backup-key-here

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Azure OpenAI (Optional)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# Volcano Ark (火山方舟)
VOLCANO_API_KEY=your-volcano-api-key-here
VOLCANO_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3

# ===========================================
# Monitoring Stack (Optional)
# ===========================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123
ALERTMANAGER_PORT=9093

# ===========================================
# Alert Notifications (Optional)
# ===========================================
# Email notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=noreply@example.com
SMTP_USER=
SMTP_PASSWORD=
EMAIL_TO=admin@example.com

# ===========================================
# Advanced Settings (Optional)
# ===========================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Redis memory limit
REDIS_MAXMEMORY=256mb

# Rate limiting (requests per second)
RATE_LIMIT=100
RATE_BURST=200

# Metrics enabled
METRICS_ENABLED=true

# Request timeout (seconds)
REQUEST_TIMEOUT=60

# Max request body size (MB)
MAX_REQUEST_SIZE=10

# ===========================================
# Cache Settings (Optional)
# ===========================================
# Enable request caching
CACHE_ENABLED=true

# Cache TTL (seconds)
CACHE_TTL=3600

# Cache max size (MB)
CACHE_MAX_SIZE=100
