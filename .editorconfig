# ============================================
# AI Gateway - EditorConfig
# Unified editor configuration
# ============================================

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.go]
indent_size = 4
indent_style = tab

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.json]
indent_size = 2

[*.yaml]
indent_size = 2

[*.yml]
indent_size = 2

[Makefile]
indent_style = tab

[Dockerfile]
indent_size = 4

[*.sql]
indent_size = 2

[*.{sh,bash}]
indent_size = 2

[.gitignore]
insert_final_newline = true

[.dockerignore]
insert_final_newline = true
