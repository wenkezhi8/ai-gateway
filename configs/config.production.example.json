{
  "server": {
    "port": "8566",
    "mode": "release"
  },
  "redis": {
    "host": "localhost",
    "port": 6379,
    "password": "",
    "db": 0
  },
  "database": {
    "path": "./data/ai-gateway.db"
  },
  "providers": [
    {
      "name": "openai",
      "api_key": "${PROVIDER_OPENAI_API_KEY}",
      "base_url": "https://api.openai.com",
      "enabled": true
    }
  ],
  "limiter": {
    "enabled": true,
    "rate": 100,
    "burst": 200,
    "per_user": true,
    "switch_timeout_ms": 3000,
    "warning_threshold": 0.9,
    "check_interval_ms": 5000
  },
  "intent_engine": {
    "enabled": false,
    "base_url": "http://127.0.0.1:18566",
    "timeout_ms": 1500,
    "language": "zh-CN",
    "expected_dimension": 1024
  },
  "vector_cache": {
    "enabled": false,
    "index_name": "idx_ai_cache_v2",
    "key_prefix": "ai:v2:cache:",
    "dimension": 1024,
    "query_timeout_ms": 1200,
    "thresholds": {
      "calc": 0.97,
      "translate": 0.96,
      "weather": 0.95,
      "qa": 0.93,
      "chat": 0.92
    },
    "ttl_seconds": {
      "calc": 2592000,
      "translate": 1209600,
      "weather": 1800,
      "qa": 86400,
      "chat": 43200
    }
  },
  "edition": {
    "type": "basic",
    "runtime": "docker",
    "dependency_versions": {
      "redis": "7.2.0-v18",
      "ollama": "latest",
      "qdrant": "latest"
    }
  },
  "chat_proxy": {
    "mode": "smart"
  }
}
